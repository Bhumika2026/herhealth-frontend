# frontend/.env.example
# Copy this to .env and fill in your values

VITE_API_URL=http://localhost:5000/api

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# Anthropic API key for Sakhi AI (client-side calls)
# NOTE: For production, proxy all AI calls through your backend instead
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
